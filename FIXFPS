local function New(class, props)
    local obj = Instance.new(class)
    for k, v in pairs(props) do obj[k] = v end
    return obj
end

local gui = New("ScreenGui", {Name = "VIP_FPS_FIXED", Parent = cg, ResetOnSpawn = false, ZIndexBehavior = Enum.ZIndexBehavior.Sibling})

local function ShowNotification(text, color)
    local notif = New("Frame", {
        Parent = gui, Size = UDim2.new(0, 280, 0, 40), Position = UDim2.new(0.5, -140, -0.1, 0),
        BackgroundColor3 = current_colors.bg, BackgroundTransparency = 0.2, BorderSizePixel = 0
    })
    New("UICorner", {Parent = notif, CornerRadius = UDim.new(0, 8)})
    New("UIStroke", {Parent = notif, Color = color, Thickness = 1})
    New("TextLabel", {
        Parent = notif, Text = text, Font = settings.font, TextColor3 = color,
        TextSize = 14, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1
    })
    local t_info = TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    ts:Create(notif, t_info, {Position = UDim2.new(0.5, -140, 0.02, 0)}):Play()
    task.wait(3)
    local hide_t = ts:Create(notif, t_info, {Position = UDim2.new(0.5, -140, -0.1, 0)})
    hide_t:Play()
    hide_t.Completed:Connect(function() notif:Destroy() end)
end

local function PlaySound()
