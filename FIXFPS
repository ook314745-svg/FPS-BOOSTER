local last_update = 0
RunService.Heartbeat:Connect(function(step)
    if tick() - last_update < 1 then return end
    last_update = tick()

    if main.Visible then
        local current_fps = math.floor(1 / step)
        local current_ping = math.floor(lp:GetNetworkPing() * 1000)
        local current_mem = math.floor(stats:GetTotalMemoryUsageMb())
        
        fps_lbl.Text = "FPS: " .. current_fps; ping_lbl.Text = "PING: " .. current_ping .. " ms"; mem_lbl.Text = "MEM: " .. current_mem .. " MB"
        
        if current_colors.ok then
            fps_lbl.TextColor3 = current_fps >= 55 and current_colors.ok or (current_fps >= 30 and current_colors.acc or current_colors.err)
            ping_lbl.TextColor3 = current_ping <= 100 and current_colors.ok or (current_ping <= 250 and current_colors.acc or current_colors.err)
        end
    end
end)


