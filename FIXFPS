local function UpdateTheme()
    local theme_hex_values = themes[current_theme_name]
    for k, v in pairs(theme_hex_values) do current_colors[k] = Color3.fromHex(v) end

    main.BackgroundColor3 = current_colors.bg; main_stroke.Color = current_colors.acc
    toggle_btn.BackgroundColor3 = current_colors.bg; toggle_btn.ImageColor3 = current_colors.acc; toggle_btn_stroke.Color = current_colors.acc
    header.TextColor3 = current_colors.acc
    
    for _, p in ipairs({page1, page2, main}) do
        for _, b in ipairs(p:GetChildren()) do
            if b:IsA("TextButton") then
                b.TextColor3 = current_colors.txt
                local stroke = b:FindFirstChildOfClass("UIStroke")
                if stroke then stroke.Color = current_colors.acc end
            end
        end
    end
    
    fps_lbl.TextColor3 = current_colors.txt; ping_lbl.TextColor3 = current_colors.txt; mem_lbl.TextColor3 = current_colors.txt
end

local function CreateButton(parent, text, pos, size, callback)
    local b = New("TextButton", {
        Parent = parent, Text = text, Font = settings.font, TextSize = 14,
        Size = size, Position = pos, BackgroundColor3 = Color3.fromRGB(20, 20, 20),
        BorderSizePixel = 0, AutoButtonColor = true
    })
    New("UICorner", {Parent = b, CornerRadius = UDim.new(0, 8)})
    New("UIStroke", {Parent = b, Thickness = 1, Transparency = 0.6})
    b.MouseButton1Click:Connect(function() PlaySound(); callback(b) end)
    return b
end


